<Window x:Class="MacroDeck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MacroDeck.ViewModels"
        Title="MacroDeck"
        Width="500" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource Text0Brush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <!-- ════════════════════════════════════════════════════════
             MAIN PAGE (visible when settings is closed)
             ════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding MainPageVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <!-- Chrome bar -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="14,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="MacroDeck" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right" Content="⚙" Style="{StaticResource IconButton}"
                            Command="{Binding OpenSettingsCommand}" ToolTip="Settings" />
                </DockPanel>
            </Border>

            <!-- Hero + Transport -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,22,0,14">
                <TextBlock Text="{Binding ElapsedDisplay}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="48" FontWeight="Light"
                           Foreground="{StaticResource Text0Brush}"
                           HorizontalAlignment="Center" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                        <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}" Text="{Binding EventCount, Mode=OneWay}" />
                        <Run Text=" EVENTS" />
                    </TextBlock>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                        <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}" Text="{Binding DiskKB, Mode=OneWay}" />
                        <Run Text=" KB" />
                    </TextBlock>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                               Foreground="{StaticResource Text2Brush}" Text="{Binding StatusText}" />
                </StackPanel>

                <TextBlock Text="{Binding SessionName}" FontSize="12" FontWeight="Medium"
                           HorizontalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Record button -->
                <Button Command="{Binding ToggleRecordCommand}" Margin="0,16,0,0" Height="48" Width="300" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="14"
                                    Background="{StaticResource ElevatedBrush}"
                                    BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse x:Name="Led" Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,12,0" />
                                    <TextBlock x:Name="Lbl" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text0Brush}" FontFamily="{StaticResource UIFont}"
                                               Text="START RECORDING" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter TargetName="Led" Property="Fill" Value="White" />
                                    <Setter TargetName="Lbl" Property="Text" Value="STOP RECORDING" />
                                    <Setter TargetName="Lbl" Property="Foreground" Value="White" />
                                </DataTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrightBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mini actions (rounded) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <!-- Play / Pause toggle -->
                    <Button Command="{Binding TogglePlayCommand}" Style="{StaticResource MiniButton}" ToolTip="Play / Pause">
                        <TextBlock FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏸" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding StopAllCommand}" Content="■" Style="{StaticResource MiniButton}" ToolTip="Stop" />
                    <Button Command="{Binding SaveCommand}" Content="💾" Style="{StaticResource MiniButton}" ToolTip="Save session" />
                    <Button Command="{Binding OpenCommand}" Content="📂" Style="{StaticResource MiniButton}" ToolTip="Open session" />
                </StackPanel>
            </StackPanel>

            <!-- Waveform -->
            <Border Grid.Row="2" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1" />

            <!-- Stream -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10">
                    <DockPanel>
                        <TextBlock Text="STREAM" DockPanel.Dock="Left" FontFamily="{StaticResource MonoFont}"
                                   FontSize="10" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                                <Run Text="{Binding EventCount, Mode=OneWay}" />
                                <Run Text=" events · live" />
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ListView Grid.Row="1" ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Padding="20,8" Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#05FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource CyanBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChipType}" Value="click">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChipType}" Value="key">
                                                    <Setter Property="Fill" Value="{StaticResource AmberBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChipType}" Value="scroll">
                                                    <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding Label}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="10" FontWeight="Medium" Foreground="{StaticResource Text0Brush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{Binding TargetDescription}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource Text1Brush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="4" Background="#26000000" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#19FFFFFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="REC" FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,7,0" VerticalAlignment="Center" />
                            <TextBlock Text="ARMED" FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="Ctrl" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="Alt" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="R" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════
             SETTINGS PAGE (visible when settings is open)
             ════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding SettingsPageVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="20,0">
                    <TextBlock Text="← Settings" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel Margin="20,16,20,20">

                    <!-- Appearance -->
                    <TextBlock Text="APPEARANCE" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Theme" FontSize="12" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="  Soft Dark" IsChecked="True" Foreground="{StaticResource Text0Brush}" FontSize="12" Margin="0,0,16,0" />
                                <RadioButton Content="  Sunset Glass" Foreground="{StaticResource Text0Brush}" FontSize="12" Margin="0,0,16,0" />
                                <RadioButton Content="  Vapor Card" Foreground="{StaticResource Text0Brush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Playback -->
                    <TextBlock Text="PLAYBACK" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,20">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Repeat" Width="100" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                                <TextBox Width="80" Text="{Binding RepeatCount}" Style="{StaticResource DarkTextBox}" />
                                <TextBlock Text="  times (−1 = infinite)" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                           Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Speed" Width="100" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                                <ComboBox Width="100" Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding PlaybackSpeed}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="0.25×" Tag="0.25" />
                                    <ComboBoxItem Content="0.50×" Tag="0.5" />
                                    <ComboBoxItem Content="0.75×" Tag="0.75" />
                                    <ComboBoxItem Content="1.00×" Tag="1.0" IsSelected="True" />
                                    <ComboBoxItem Content="1.50×" Tag="1.5" />
                                    <ComboBoxItem Content="2.00×" Tag="2.0" />
                                    <ComboBoxItem Content="4.00×" Tag="4.0" />
                                </ComboBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="Abort on move" Width="100" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding AbortOnMove}" Style="{StaticResource DarkCheckBox}" />
                                <TextBlock Text="  Stop if mouse moves" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                           Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Hotkeys -->
                    <TextBlock Text="GLOBAL HOTKEYS" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,20">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Toggle Record" Width="120" FontSize="12" Foreground="{StaticResource Text1Brush}" />
                                <TextBlock Text="Ctrl + Alt + R" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Toggle Play" Width="120" FontSize="12" Foreground="{StaticResource Text1Brush}" />
                                <TextBlock Text="Ctrl + Alt + P" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Stop Record" Width="120" FontSize="12" Foreground="{StaticResource Text1Brush}" />
                                <TextBlock Text="Ctrl + Alt + S" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="Stop Play" Width="120" FontSize="12" Foreground="{StaticResource Text1Brush}" />
                                <TextBlock Text="Ctrl + Alt + ." FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <TextBlock Text="HELP &amp; ABOUT" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,10" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Version" Width="90" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" />
                                <TextBlock Text="0.1.0" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Author" Width="90" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" />
                                <TextBlock Text="Damilola Onadeinde" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" />
                            </DockPanel>
                            <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,6,0,0"
                                       Text="damilola.onadeinde@gmail.com" Cursor="Hand" />
                            <TextBlock Text="MacroDeck is a precision mouse and keyboard macro recorder. Capture gestures, replay with configurable speed, bind global hotkeys, and save sessions as cross-platform JSON."
                                       FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}"
                                       TextWrapping="Wrap" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer (Save + Cancel) -->
            <Border Grid.Row="2" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SettingsButton}"
                                Command="{Binding CloseSettingsCommand}" Margin="0,0,8,0" />
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveSettingsCommand}" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
