<Window x:Class="MacroDeck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MacroDeck.ViewModels"
        Title="MacroDeck"
        Width="500" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource Text0Brush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />      <!-- Chrome bar -->
            <RowDefinition Height="Auto" />    <!-- Hero + Transport -->
            <RowDefinition Height="36" />      <!-- Waveform -->
            <RowDefinition Height="*" />       <!-- Stream -->
            <RowDefinition Height="36" />      <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Chrome bar ═══ -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="MacroDeck" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SessionName}" FontSize="11" FontWeight="Normal"
                               Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"
                               Margin="8,0,0,0" MaxWidth="220" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SessionName}" Value="Untitled Session">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button DockPanel.Dock="Right" Content="⚙" Style="{StaticResource IconButton}"
                        Command="{Binding OpenSettingsCommand}" ToolTip="Settings" />
            </DockPanel>
        </Border>

        <!-- ═══ Hero + Transport ═══ -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,24,0,14">

            <!-- Timecode -->
            <TextBlock Text="{Binding ElapsedDisplay}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="48" FontWeight="Light"
                       Foreground="{StaticResource Text0Brush}"
                       HorizontalAlignment="Center" />

            <!-- Meta row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                           Foreground="{StaticResource Text2Brush}">
                    <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}"
                         Text="{Binding EventCount, Mode=OneWay}" />
                    <Run Text=" EVENTS" />
                </TextBlock>
                <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="14,0" VerticalAlignment="Center" />
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                           Foreground="{StaticResource Text2Brush}">
                    <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}"
                         Text="{Binding DiskKB, Mode=OneWay}" />
                    <Run Text=" KB" />
                </TextBlock>
                <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="14,0" VerticalAlignment="Center" />
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                           Foreground="{StaticResource Text2Brush}"
                           Text="{Binding StatusText}" />
            </StackPanel>

            <!-- Session name -->
            <TextBlock Text="{Binding SessionName}"
                       FontSize="12" FontWeight="Medium"
                       HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Record button -->
            <Button Command="{Binding ToggleRecordCommand}"
                    Margin="0,16,0,0" Height="48" Width="300" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="14"
                                Background="{StaticResource ElevatedBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Ellipse x:Name="Led" Width="9" Height="9"
                                         Fill="{StaticResource AccentBrush}" Margin="0,0,12,0" />
                                <TextBlock x:Name="Lbl" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text0Brush}"
                                           FontFamily="{StaticResource UIFont}"
                                           Text="START RECORDING" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Led" Property="Fill" Value="White" />
                                <Setter TargetName="Lbl" Property="Text" Value="STOP RECORDING" />
                                <Setter TargetName="Lbl" Property="Foreground" Value="White" />
                            </DataTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource BorderBrightBrush}" />
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Mini actions (rounded corners) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Command="{Binding TogglePlayCommand}" Content="▶"
                        Style="{StaticResource MiniButton}" ToolTip="Play" />
                <Button Command="{Binding StopAllCommand}" Content="■"
                        Style="{StaticResource MiniButton}" ToolTip="Stop" />
                <Button Command="{Binding SaveCommand}" Content="💾"
                        Style="{StaticResource MiniButton}" ToolTip="Save session" />
                <Button Command="{Binding OpenCommand}" Content="📂"
                        Style="{StaticResource MiniButton}" ToolTip="Open session" />
            </StackPanel>
        </StackPanel>

        <!-- ═══ Waveform ═══ -->
        <Border Grid.Row="2" Background="{StaticResource ElevatedBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1" />

        <!-- ═══ Stream ═══ -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Stream header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="20,10">
                <DockPanel>
                    <TextBlock Text="STREAM" DockPanel.Dock="Left"
                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{StaticResource Text2Brush}">
                            <Run Text="{Binding EventCount, Mode=OneWay}" />
                            <Run Text=" events · live" />
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Event list -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Events}"
                      SelectedItem="{Binding SelectedEvent}"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Foreground="{StaticResource Text1Brush}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Padding="20,8" Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource AccentSoftBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="#05FFFFFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource CyanBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ChipType}" Value="click">
                                                <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChipType}" Value="key">
                                                <Setter Property="Fill" Value="{StaticResource AmberBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ChipType}" Value="scroll">
                                                <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="10"
                                       FontWeight="Medium" Foreground="{StaticResource Text0Brush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />

                            <TextBlock Grid.Column="2" Text="{Binding TargetDescription}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       Foreground="{StaticResource Text1Brush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ═══ Status bar ═══ -->
        <Border Grid.Row="4" Background="#26000000"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                        <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#19FFFFFF" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="REC" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="ARMED" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                            Padding="5,2" Margin="2,0">
                        <TextBlock Text="Ctrl" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="{StaticResource Text1Brush}" />
                    </Border>
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                            Padding="5,2" Margin="2,0">
                        <TextBlock Text="Alt" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="{StaticResource Text1Brush}" />
                    </Border>
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                            Padding="5,2" Margin="2,0">
                        <TextBlock Text="R" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                   Foreground="{StaticResource Text1Brush}" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
