<Window x:Class="MacroDeck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MacroDeck.ViewModels"
        Title="MacroDeck" Width="500" Height="640"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}" Foreground="{StaticResource Text0Brush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Shared logo template -->
    <Window.Resources>
        <DataTemplate x:Key="LogoTemplate">
            <Border CornerRadius="10" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1.5"
                    Width="44" Height="44" Padding="8,9,8,9">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="0,0,5,0" />
                        <Rectangle Width="18" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Text2Brush}" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AmberBrush}" Margin="0,0,5,0" />
                        <Rectangle Width="13" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Text2Brush}" Opacity="0.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource CyanBrush}" Margin="0,0,5,0" />
                        <Rectangle Width="16" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource Text2Brush}" Opacity="0.5" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- ════════════════════════════════════════
             MAIN PAGE
             ════════════════════════════════════════ -->
        <Grid Visibility="{Binding MainPageVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <!-- Chrome bar -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <!-- Left: logo + title -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <ContentControl ContentTemplate="{StaticResource LogoTemplate}" Width="24" Height="24"
                                        RenderTransformOrigin="0.5,0.5">
                            <ContentControl.RenderTransform>
                                <ScaleTransform ScaleX="0.55" ScaleY="0.55" />
                            </ContentControl.RenderTransform>
                        </ContentControl>
                        <TextBlock Text="MacroDeck" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                    <!-- Right: gear -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Content="⚙" Style="{StaticResource IconButton}"
                            Command="{Binding OpenSettingsCommand}" ToolTip="Settings" />
                </Grid>
            </Border>

            <!-- Hero + Transport -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,12">
                <TextBlock Text="{Binding ElapsedDisplay}"
                           FontFamily="{StaticResource MonoFont}" FontSize="46" FontWeight="Light"
                           Foreground="{StaticResource Text0Brush}" HorizontalAlignment="Center" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                        <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}" Text="{Binding EventCount, Mode=OneWay}" />
                        <Run Text=" EVENTS" />
                    </TextBlock>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="12,0" VerticalAlignment="Center" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                        <Run FontWeight="Medium" Foreground="{StaticResource Text1Brush}" Text="{Binding DiskKB, Mode=OneWay}" />
                        <Run Text=" KB" />
                    </TextBlock>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Text3Brush}" Margin="12,0" VerticalAlignment="Center" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" Text="{Binding StatusText}" />
                </StackPanel>

                <TextBlock Text="{Binding SessionName}" FontSize="12" FontWeight="Medium"
                           HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Record button -->
                <Button Command="{Binding ToggleRecordCommand}" Margin="0,14,0,0" Height="46" Width="280" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="14" Background="{StaticResource ElevatedBrush}"
                                    BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse x:Name="Led" Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,12,0" />
                                    <TextBlock x:Name="Lbl" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text0Brush}" Text="START RECORDING" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter TargetName="Led" Property="Fill" Value="White" />
                                    <Setter TargetName="Lbl" Property="Text" Value="STOP RECORDING" />
                                    <Setter TargetName="Lbl" Property="Foreground" Value="White" />
                                </DataTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrightBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mini actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Command="{Binding TogglePlayCommand}" Style="{StaticResource MiniButton}" ToolTip="Play / Pause">
                        <TextBlock FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏸" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding StopAllCommand}" Content="■" Style="{StaticResource MiniButton}" ToolTip="Stop" />
                    <Button Command="{Binding SaveCommand}" Content="💾" Style="{StaticResource MiniButton}" ToolTip="Save" />
                    <Button Command="{Binding OpenCommand}" Content="📂" Style="{StaticResource MiniButton}" ToolTip="Open" />
                </StackPanel>
            </StackPanel>

            <!-- Waveform -->
            <Border Grid.Row="2" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1" />

            <!-- Stream -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10">
                    <Grid>
                        <TextBlock Text="STREAM" HorizontalAlignment="Left" FontFamily="{StaticResource MonoFont}"
                                   FontSize="10" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                                <Run Text="{Binding EventCount, Mode=OneWay}" /><Run Text=" events · live" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
                <ListView Grid.Row="1" ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent}"
                          Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Padding="20,8" Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#05FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource CyanBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChipType}" Value="click">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChipType}" Value="key">
                                                    <Setter Property="Fill" Value="{StaticResource AmberBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChipType}" Value="scroll">
                                                    <Setter Property="Fill" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding Label}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="10" FontWeight="Medium" Foreground="{StaticResource Text0Brush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{Binding TargetDescription}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource Text1Brush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="4" Background="#26000000" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#19FFFFFF" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="REC" FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,14,0" />
                        <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="ARMED" FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Medium" Foreground="{StaticResource Text2Brush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="Ctrl" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="Alt" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                        <Border Background="{StaticResource ElevatedBrush}" CornerRadius="4" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="5,2" Margin="2,0">
                            <TextBlock Text="R" FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text1Brush}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════
             SETTINGS PAGE
             ════════════════════════════════════════ -->
        <Grid Visibility="{Binding SettingsPageVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource ElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="← Settings" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center"
                               HorizontalAlignment="Left" />
                </Grid>
            </Border>

            <!-- Scrollable settings content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,20">

                    <!-- ─── Appearance ─── -->
                    <TextBlock Text="APPEARANCE" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Theme" FontSize="12" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="  Soft Dark" IsChecked="True" Foreground="{StaticResource Text0Brush}" FontSize="12" Margin="0,0,16,0" GroupName="Theme" />
                                <RadioButton Content="  Sunset Glass" Foreground="{StaticResource Text0Brush}" FontSize="12" Margin="0,0,16,0" GroupName="Theme" />
                                <RadioButton Content="  Vapor Card" Foreground="{StaticResource Text0Brush}" FontSize="12" GroupName="Theme" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ─── Playback ─── -->
                    <TextBlock Text="PLAYBACK" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Repeat" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Width="80" Text="{Binding RepeatCount}" Style="{StaticResource DarkTextBox}" />
                                <TextBlock Text="  times · type −1 for infinite" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Speed" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox Width="100" Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding PlaybackSpeed}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="0.25×" Tag="0.25" />
                                    <ComboBoxItem Content="0.50×" Tag="0.5" />
                                    <ComboBoxItem Content="0.75×" Tag="0.75" />
                                    <ComboBoxItem Content="1.00×" Tag="1.0" IsSelected="True" />
                                    <ComboBoxItem Content="1.50×" Tag="1.5" />
                                    <ComboBoxItem Content="2.00×" Tag="2.0" />
                                    <ComboBoxItem Content="4.00×" Tag="4.0" />
                                </ComboBox>
                                <TextBlock Text="  playback multiplier" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Start delay" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox Width="100" Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding StartDelay}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="None" Tag="0" IsSelected="True" />
                                    <ComboBoxItem Content="1 second" Tag="1" />
                                    <ComboBoxItem Content="2 seconds" Tag="2" />
                                    <ComboBoxItem Content="3 seconds" Tag="3" />
                                    <ComboBoxItem Content="5 seconds" Tag="5" />
                                    <ComboBoxItem Content="10 seconds" Tag="10" />
                                    <ComboBoxItem Content="30 seconds" Tag="30" />
                                </ComboBox>
                                <TextBlock Text="  seconds before playback" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Humanize" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="  Off" IsChecked="True" Foreground="{StaticResource Text0Brush}" FontSize="11" Margin="0,0,12,0" GroupName="Humanize" />
                                <RadioButton Content="  Subtle" Foreground="{StaticResource Text0Brush}" FontSize="11" Margin="0,0,12,0" GroupName="Humanize" />
                                <RadioButton Content="  Strong" Foreground="{StaticResource Text0Brush}" FontSize="11" GroupName="Humanize" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Abort on move" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding AbortOnMove}" Style="{StaticResource DarkCheckBox}" />
                                <TextBlock Text="  stop if user moves mouse" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ─── Global Hotkeys ─── -->
                    <TextBlock Text="GLOBAL HOTKEYS" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Toggle Record" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl + Alt + R" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Toggle Play" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl + Alt + P" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Stop Record" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Ctrl + Alt + S" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stop Play" FontSize="12" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Ctrl + Alt + ." FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- ─── Schedule Playback ─── -->
                    <TextBlock Text="SCHEDULE PLAYBACK" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Scheduled playback coming soon." FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}" />
                        </StackPanel>
                    </Border>

                    <!-- ─── Session ─── -->
                    <TextBlock Text="SESSION" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Save session…" Style="{StaticResource SettingsButton}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                                <Button Content="Open session…" Style="{StaticResource SettingsButton}" Command="{Binding OpenCommand}" Margin="0,0,8,0" />
                                <Button Content="Clear" Style="{StaticResource SettingsButton}" Command="{Binding ClearCommand}" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}">
                                <Run Text="{Binding EventCount, Mode=OneWay}" /><Run Text=" events buffered" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ─── Help & About ─── -->
                    <TextBlock Text="HELP &amp; ABOUT" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <!-- Logo + name -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ContentControl ContentTemplate="{StaticResource LogoTemplate}" />
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock Text="MacroDeck" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text0Brush}" />
                                    <TextBlock Text="Version 0.1.0 · Build 2026.04.17" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" />
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="24" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="0.1.0" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Build" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="2026.04.17" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Author" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Damilola Onadeinde" FontFamily="{StaticResource MonoFont}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center" />
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,6,0,10" />

                            <TextBlock Text="✉  damilola.onadeinde@gmail.com" FontSize="12" Foreground="{StaticResource AccentBrush}" Cursor="Hand" Margin="0,0,0,10" />

