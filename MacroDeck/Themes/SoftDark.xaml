<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surface colors -->
    <Color x:Key="WindowBg">#FF0D0D11</Color>
    <Color x:Key="Elevated">#FF15151C</Color>
    <Color x:Key="Hover">#FF1C1C25</Color>

    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBg}" />
    <SolidColorBrush x:Key="ElevatedBrush" Color="{StaticResource Elevated}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource Hover}" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="BorderMidBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="BorderBrightBrush" Color="#2EFFFFFF" />

    <!-- Text -->
    <SolidColorBrush x:Key="Text0Brush" Color="#FFEDEDF0" />
    <SolidColorBrush x:Key="Text1Brush" Color="#FF9A9BA8" />
    <SolidColorBrush x:Key="Text2Brush" Color="#FF797A8A" />
    <SolidColorBrush x:Key="Text3Brush" Color="#FF3A3B45" />

    <!-- Accent -->
    <Color x:Key="Accent">#FFEF4444</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1FEF4444" />

    <!-- Event type colors -->
    <SolidColorBrush x:Key="CyanBrush" Color="#FF22D3EE" />
    <SolidColorBrush x:Key="AmberBrush" Color="#FFF59E0B" />
    <SolidColorBrush x:Key="GreenBrush" Color="#FF10B981" />

    <!-- Fonts -->
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>
    <FontFamily x:Key="UIFont">Segoe UI, Tahoma</FontFamily>

    <!-- ═══ Reusable button styles ═══ -->

    <!-- Mini action button (Play, Stop, Save, Open) — rounded corners -->
    <Style x:Key="MiniButton" TargetType="Button">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="9"
                            Background="{StaticResource ElevatedBrush}"
                            BorderBrush="{StaticResource BorderMidBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource HoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource BorderBrightBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource WindowBgBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Gear / icon button — rounded, smaller -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="7"
                            Background="{StaticResource ElevatedBrush}"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource HoverBrush}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource Text0Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
