<Window x:Class="MacroDeck.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MacroDeck · Settings"
        Width="500" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource Text0Brush}"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="*" />       <!-- Content -->
            <RowDefinition Height="Auto" />   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource ElevatedBrush}" Padding="24,16">
            <TextBlock Text="Settings" FontSize="17" FontWeight="SemiBold"
                       Foreground="{StaticResource Text0Brush}" />
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel>

                <!-- ─── Playback ─── -->
                <TextBlock Text="PLAYBACK" FontFamily="{StaticResource MonoFont}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Text2Brush}"
                           Margin="0,0,0,10" />
                <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                        Padding="14" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Repeat -->
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Repeat" Width="100" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBox x:Name="RepeatBox" Width="80" Text="{Binding RepeatCount}"
                                     Background="{StaticResource WindowBgBrush}"
                                     Foreground="{StaticResource Text0Brush}"
                                     BorderBrush="{StaticResource BorderStrongBrush}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Padding="8,5" />
                            <TextBlock Text="times (−1 for infinite)" FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                        </DockPanel>

                        <!-- Speed -->
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Speed" Width="100" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="SpeedBox" Width="100"
                                      SelectedValue="{Binding PlaybackSpeed}"
                                      SelectedValuePath="Tag"
                                      Background="{StaticResource WindowBgBrush}"
                                      Foreground="{StaticResource Text0Brush}"
                                      BorderBrush="{StaticResource BorderStrongBrush}"
                                      FontFamily="{StaticResource MonoFont}" FontSize="12">
                                <ComboBoxItem Content="0.25×" Tag="0.25" />
                                <ComboBoxItem Content="0.50×" Tag="0.5" />
                                <ComboBoxItem Content="0.75×" Tag="0.75" />
                                <ComboBoxItem Content="1.00×" Tag="1.0" IsSelected="True" />
                                <ComboBoxItem Content="1.50×" Tag="1.5" />
                                <ComboBoxItem Content="2.00×" Tag="2.0" />
                                <ComboBoxItem Content="4.00×" Tag="4.0" />
                            </ComboBox>
                        </DockPanel>

                        <!-- Abort on move -->
                        <DockPanel>
                            <TextBlock Text="Abort on move" Width="100" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <CheckBox IsChecked="{Binding AbortOnMove}" VerticalAlignment="Center" />
                            <TextBlock Text="Stop playback if mouse moves" FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Global Hotkeys ─── -->
                <TextBlock Text="GLOBAL HOTKEYS" FontFamily="{StaticResource MonoFont}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Text2Brush}"
                           Margin="0,0,0,10" />
                <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                        Padding="14" Margin="0,0,0,20">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Toggle Record" Width="120" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="Ctrl + Alt + R" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Toggle Play" Width="120" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="Ctrl + Alt + P" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Stop Record" Width="120" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="Ctrl + Alt + S" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Stop Play" Width="120" FontSize="12"
                                       Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="Ctrl + Alt + ." FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Session ─── -->
                <TextBlock Text="SESSION" FontFamily="{StaticResource MonoFont}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Text2Brush}"
                           Margin="0,0,0,10" />
                <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                        Padding="14" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Save session…" Command="{Binding SaveCommand}" Padding="10,5" Margin="0,0,8,0" />
                            <Button Content="Open session…" Command="{Binding OpenCommand}" Padding="10,5" Margin="0,0,8,0" />
                            <Button Content="Clear" Command="{Binding ClearCommand}" Padding="10,5"
                                    Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{StaticResource Text2Brush}">
                            <Run Text="{Binding EventCount, Mode=OneWay}" />
                            <Run Text=" events buffered" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ─── About ─── -->
                <TextBlock Text="HELP &amp; ABOUT" FontFamily="{StaticResource MonoFont}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Text2Brush}"
                           Margin="0,0,0,10" />
                <Border Background="{StaticResource ElevatedBrush}" CornerRadius="9"
                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                        Padding="14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Version" Width="90" FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}" />
                            <TextBlock Text="0.1.0" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Build" Width="90" FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}" />
                            <TextBlock Text="2026.04.16" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Author" Width="90" FontFamily="{StaticResource MonoFont}"
                                       FontSize="10" Foreground="{StaticResource Text2Brush}" />
                            <TextBlock Text="Damilola Onadeinde" FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text0Brush}" />
                        </DockPanel>
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                <Hyperlink NavigateUri="mailto:damilola.onadeinde@gmail.com"
                                           Foreground="{StaticResource AccentBrush}"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    damilola.onadeinde@gmail.com
                                </Hyperlink>
                            </TextBlock>
                        </DockPanel>
                        <TextBlock Text="MacroDeck is a precision mouse and keyboard macro recorder. Capture gestures, replay them with configurable speed and timing, bind global hotkeys, and save sessions as cross-platform JSON."
                                   FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{StaticResource Text2Brush}"
                                   TextWrapping="Wrap" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource ElevatedBrush}" Padding="24,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Close" Padding="16,6"
                        Click="Close_Click" IsCancel="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
